color: white;
text-decoration: none;
border-radius: 5px;
}

section {
padding: 40px 20px;
max-width: 900px;
margin: auto;
background: white;
margin-top: 20px;
border-radius: 10px;
}

h2 {
color: #333;
}

.services, .portfolio {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
gap: 15px;
}

.card {
background: #eee;
padding: 15px;
border-radius: 10px;
}

footer {
text-align: center;
padding: 20px;
margin-top: 20px;
background: #111;
