<div class="services">
<div class="card">🔧 Riparazioni</div>
<div class="card">🏠 Lavori domestici</div>
<div class="card">⚡ Installazioni</div>
<div class="card">🧰 Assistenza tecnica</div>
</div>
</section>

<section>
<h2>Lavori svolti</h2>
<div class="portfolio">
<div class="card">Progetto 1</div>
<div class="card">Progetto 2</div>
<div class="card">Progetto 3</div>
</div>
</section>

<section id="contatti">
<h2>Contatti</h2>
<p>📞 Telefono: +39 XXX XXX XXXX</p>
<p>📧 Email: tuo@email.it</p>
</section>

<footer>
<p>© 2026 - Tutti i diritti riservati</p>
</footer>

</body>
</html>
